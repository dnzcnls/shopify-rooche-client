<section class="editorial-split">
  {%- for block in section.blocks -%}
    <div class="editorial-card">
      {%- if block.settings.image != blank -%}
        <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
      {%- else -%}
        <img src="{{ block.settings.fallback_asset | asset_url }}" alt="" loading="lazy">
      {%- endif -%}
      <div class="editorial-card-content">
        <div class="editorial-card-chapter">{{ block.settings.chapter }}</div>
        <h2 class="editorial-card-title">{{ block.settings.title }}</h2>
        <a href="{{ block.settings.link }}" class="editorial-card-link hover-underline">{{ block.settings.link_text }} →</a>
      </div>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Editorial split",
  "max_blocks": 2,
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "editorial-1.jpg" },
        { "type": "text", "id": "chapter", "label": "Chapter label", "default": "Chapitre I" },
        { "type": "text", "id": "title", "label": "Title", "default": "L'Atelier" },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Ready-to-Wear" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{
    "name": "Editorial split",
    "blocks": [
      { "type": "card", "settings": { "chapter": "Chapitre I", "title": "L'Atelier", "link_text": "Ready-to-Wear", "fallback_asset": "editorial-1.jpg" } },
      { "type": "card", "settings": { "chapter": "Chapitre II", "title": "La Joaillerie", "link_text": "Fine Jewelry", "fallback_asset": "editorial-2.jpg" } }
    ]
  }]
}
{% endschema %}
