<section class="page-head">
  <div class="page-eyebrow">Client Account</div>
  <h1 class="page-title">{{ 'customer.account.title' | t }}</h1>
</section>

<section style="padding: 48px 24px; max-width: 960px; margin: 0 auto;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:32px;">
    <div>
      <div class="font-display" style="font-size:24px;">Welcome, {{ customer.first_name }}</div>
      <div style="font-size:13px; color:var(--muted-fg); margin-top:4px;">{{ customer.email }}</div>
    </div>
    <a href="{{ routes.account_logout_url }}" class="text-xs tracking-luxe hover-underline">Sign Out</a>
  </div>

  <h2 class="font-display" style="font-size:24px; margin-bottom:24px; border-top: 1px solid var(--border); padding-top: 32px;">Order History</h2>
  {%- if customer.orders.size > 0 -%}
    <table style="width:100%; border-collapse: collapse; font-size:14px;">
      <thead>
        <tr style="text-align:left; font-size:10px; letter-spacing:0.32em; text-transform:uppercase; color:var(--muted-fg); border-bottom: 1px solid var(--border);">
          <th style="padding:12px 0;">Order</th><th>Date</th><th>Status</th><th style="text-align:right;">Total</th>
        </tr>
      </thead>
      <tbody>
        {%- for order in customer.orders -%}
          <tr style="border-bottom: 1px solid var(--border);">
            <td style="padding:16px 0;"><a href="{{ order.customer_url }}" class="hover-underline">{{ order.name }}</a></td>
            <td>{{ order.created_at | date: '%b %d, %Y' }}</td>
            <td>{{ order.financial_status_label }}</td>
            <td style="text-align:right;">{{ order.total_price | money_without_trailing_zeros }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  {%- else -%}
    <p style="color:var(--muted-fg); font-size:14px;">You have no orders yet.</p>
  {%- endif -%}

  <h2 class="font-display" style="font-size:24px; margin: 64px 0 24px; border-top: 1px solid var(--border); padding-top: 32px;">Default Address</h2>
  {%- if customer.default_address != nil -%}
    <div style="font-size:14px; line-height: 1.7;">
      {{ customer.default_address | format_address }}
    </div>
  {%- else -%}
    <p style="color:var(--muted-fg); font-size:14px;">No address on file.</p>
  {%- endif -%}
  <a href="{{ routes.account_addresses_url }}" class="text-xs tracking-luxe hover-underline" style="display:inline-block; margin-top:16px;">Manage Addresses →</a>
</section>

{% schema %}
{ "name": "Account" }
{% endschema %}
