<div class="auth-shell">
  <div class="auth-image" style="order:2;">
    <img src="{{ 'editorial-2.jpg' | asset_url }}" alt="">
    <div class="auth-image-overlay"></div>
    <a href="{{ routes.root_url }}" class="auth-image-logo">
      <div class="font-display" style="font-size:24px;">MAISON NOIR</div>
      <div style="font-size:9px; letter-spacing:0.32em; text-transform:uppercase; opacity:0.8; margin-top:4px;">Paris — Est. MMXXV</div>
    </a>
    <div class="auth-image-quote">
      <div style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; opacity:0.7; margin-bottom:12px;">Le Mot de la Maison</div>
      <p class="font-display" style="font-size:24px; line-height:1.3;">"To dress with intent is the first act of self-respect."</p>
    </div>
  </div>
  <div class="auth-form">
    <div class="auth-form-inner">
      <div class="page-eyebrow" style="margin-bottom:12px;">Devenir Client</div>
      <h1>Join the Maison</h1>
      <p class="subtitle">Create an account to receive private collection previews, atelier invitations, and the editorial Journal.</p>

      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <ul class="errors-list">
            {%- for field in form.errors -%}
              <li>{{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="field-row">
          <div class="field">
            <label for="FirstName">First Name</label>
            <input type="text" name="customer[first_name]" id="FirstName" required>
          </div>
          <div class="field">
            <label for="LastName">Last Name</label>
            <input type="text" name="customer[last_name]" id="LastName" required>
          </div>
        </div>
        <div class="field">
          <label for="Email">Email Address</label>
          <input type="email" name="customer[email]" id="Email" autocomplete="email" required>
        </div>
        <div class="field">
          <label for="Password">Password</label>
          <input type="password" name="customer[password]" id="Password" autocomplete="new-password" required>
        </div>

        <label class="checkbox-row">
          <input type="checkbox" name="customer[accepts_marketing]" value="1" checked>
          <span>I wish to receive editorial notes, private invitations, and collection previews from Maison Noir.</span>
        </label>

        <div style="margin-top: 32px;">
          <button type="submit" class="btn btn-primary btn-block">Create Account</button>
        </div>

        <p class="legal-note">By creating an account, you agree to the Maison Noir Terms of Service and Privacy Policy.</p>
      {%- endform -%}

      <div class="auth-divider"><span>Or</span></div>

      <p style="text-align:center; font-size:14px; color:var(--muted-fg);">
        Already a client? <a href="{{ routes.account_login_url }}" class="text-link hover-underline">Sign In</a>
      </p>
    </div>
  </div>
</div>
