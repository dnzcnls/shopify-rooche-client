<div class="auth-shell">
  <div class="auth-image">
    <img src="{{ 'editorial-1.jpg' | asset_url }}" alt="">
    <div class="auth-image-overlay"></div>
    <a href="{{ routes.root_url }}" class="auth-image-logo">
      <div class="font-display" style="font-size:24px;">MAISON NOIR</div>
      <div style="font-size:9px; letter-spacing:0.32em; text-transform:uppercase; opacity:0.8; margin-top:4px;">Paris — Est. MMXXV</div>
    </a>
    <div class="auth-image-quote">
      <div style="font-size:10px; letter-spacing:0.32em; text-transform:uppercase; opacity:0.7; margin-bottom:12px;">Le Mot de la Maison</div>
      <p class="font-display" style="font-size:24px; line-height:1.3;">"To dress with intent is the first act of self-respect."</p>
    </div>
  </div>
  <div class="auth-form">
    <div class="auth-form-inner">
      <div class="page-eyebrow" style="margin-bottom:12px;">Client Account</div>
      <h1>Welcome Back</h1>
      <p class="subtitle">Sign in to your Maison Noir account to access your orders, wishlist, and private invitations.</p>

      {%- form 'customer_login' -%}
        {%- if form.errors -%}
          <ul class="errors-list">
            {%- for field in form.errors -%}
              <li>{{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="field">
          <label for="CustomerEmail">Email Address</label>
          <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" required>
        </div>
        <div class="field">
          <label for="CustomerPassword">Password</label>
          <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" required>
        </div>

        <div class="form-row-between">
          <label><input type="checkbox" name="remember"> Remember Me</label>
          <a href="#recover" class="hover-underline" onclick="document.getElementById('RecoverForm').style.display='block';this.parentElement.parentElement.style.display='none';return false;">Forgot password?</a>
        </div>

        <button type="submit" class="btn btn-primary btn-block">Sign In</button>
      {%- endform -%}

      <div id="RecoverForm" style="display:none; margin-top:24px;">
        {%- form 'recover_customer_password' -%}
          {%- if form.posted_successfully? -%}
            <div class="success-msg">We've sent reset instructions to your email.</div>
          {%- endif -%}
          <div class="field">
            <label for="RecoverEmail">Email for Password Reset</label>
            <input type="email" name="email" id="RecoverEmail" required>
          </div>
          <button type="submit" class="btn btn-outline btn-block">Send Reset Link</button>
        {%- endform -%}
      </div>

      <div class="auth-divider"><span>Or</span></div>

      <p style="text-align:center; font-size:14px; color:var(--muted-fg);">
        New to Maison Noir? <a href="{{ routes.account_register_url }}" class="text-link hover-underline">Create an Account</a>
      </p>
    </div>
  </div>
</div>
