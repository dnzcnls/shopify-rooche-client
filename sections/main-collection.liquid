{%- paginate collection.products by 24 -%}

<section class="page-head">
  <div class="page-eyebrow">Collection MMXXV</div>
  <h1 class="page-title">{{ collection.title }}</h1>
  {%- if collection.description != blank -%}
    <p class="page-subtitle">{{ collection.description }}</p>
  {%- endif -%}

  {%- if section.settings.show_filters -%}
    <div class="filter-tabs">
      <a href="{{ routes.collections_url }}/all"{% if collection.handle == 'all' %} class="active"{% endif %}>All</a>
      {%- for link in linklists[section.settings.filter_menu].links -%}
        <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<div class="collection-toolbar">
  <div>{{ collection.products_count }} {% if collection.products_count == 1 %}Piece{% else %}Pieces{% endif %}</div>
  <div>Sort — Featured</div>
</div>

<section style="padding-bottom: 80px;">
  {%- if collection.products.size > 0 -%}
    <div class="product-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p style="text-align:center; padding:80px 24px; color:var(--muted-fg);">No products in this collection yet.</p>
  {%- endif -%}

  {%- if paginate.pages > 1 -%}
    <div style="display:flex; justify-content:center; gap:24px; margin-top:64px; font-size:11px; letter-spacing:0.22em; text-transform:uppercase;">
      {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">← Previous</a>{%- endif -%}
      <span>Page {{ paginate.current_page }} / {{ paginate.pages }}</span>
      {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
    </div>
  {%- endif -%}
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "checkbox", "id": "show_filters", "label": "Show filter tabs", "default": true },
    { "type": "link_list", "id": "filter_menu", "label": "Filter menu", "default": "main-menu" }
  ]
}
{% endschema %}
