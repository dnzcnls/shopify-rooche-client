{%- if cart.item_count == 0 -%}
  <section class="cart-empty">
    <div class="page-eyebrow">Your Shopping Bag</div>
    <h1>It awaits.</h1>
    <p>Your bag is currently empty. Discover the new collection to begin.</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Continue Shopping</a>
  </section>
{%- else -%}
  <section class="page-head">
    <div class="page-eyebrow">{{ cart.item_count }} {% if cart.item_count == 1 %}Piece{% else %}Pieces{% endif %}</div>
    <h1 class="page-title">Shopping Bag</h1>
  </section>

  <form action="{{ routes.cart_url }}" method="post" novalidate>
    <div class="cart-layout">
      <div class="cart-items">
        {%- for item in cart.items -%}
          <div class="cart-item" data-cart-item="{{ item.key }}">
            <a href="{{ item.url }}" class="cart-item-img">
              <img src="{{ item.image | image_url: width: 400 }}" alt="{{ item.product.title | escape }}">
            </a>
            <div>
              {%- if item.product.type != blank -%}
                <div class="cart-item-cat">{{ item.product.type }}</div>
              {%- endif -%}
              <a href="{{ item.url }}" class="cart-item-name hover-underline">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <div class="cart-item-variant">
                  {%- for option in item.options_with_values -%}
                    {{ option.name }}: {{ option.value }}{% unless forloop.last %} · {% endunless %}
                  {%- endfor -%}
                </div>
              {%- endunless -%}
              <div class="qty-control">
                <button type="button" data-qty-minus aria-label="Decrease">−</button>
                <span data-qty-value>{{ item.quantity }}</span>
                <button type="button" data-qty-plus aria-label="Increase">+</button>
              </div>
            </div>
            <div class="cart-item-right">
              <button type="button" data-remove class="cart-item-remove" aria-label="Remove">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
              <div>{{ item.final_line_price | money_without_trailing_zeros }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <aside class="cart-summary">
        <div class="cart-summary-title">Order Summary</div>
        <div class="cart-summary-row"><span>Subtotal</span><span>{{ cart.items_subtotal_price | money_without_trailing_zeros }}</span></div>
        <div class="cart-summary-row"><span>Shipping</span><span>Complimentary</span></div>
        <div class="cart-summary-row"><span>Duties & Taxes</span><span>At checkout</span></div>
        <div class="cart-summary-total"><span>Total</span><span>{{ cart.total_price | money_without_trailing_zeros }}</span></div>
        <button type="submit" name="checkout" class="btn btn-primary btn-block">Proceed to Checkout</button>
        <a href="{{ routes.all_products_collection_url }}" style="display:block; text-align:center; margin-top:16px; font-size:11px; letter-spacing:0.32em; text-transform:uppercase; color:var(--muted-fg);">Continue Shopping</a>
        <p class="cart-note">Items hand-delivered in Maison Noir signature ivory and noir packaging. Complimentary returns within 30 days.</p>
      </aside>
    </div>
  </form>
{%- endif -%}

{% schema %}
{ "name": "Cart" }
{% endschema %}
