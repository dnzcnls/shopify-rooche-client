<section class="page-head">
  <div class="page-eyebrow">{{ section.settings.eyebrow }}</div>
  <h1 class="page-title">{{ page.title }}</h1>
  {%- if section.settings.subtitle != blank -%}
    <p class="page-subtitle">{{ section.settings.subtitle }}</p>
  {%- endif -%}
</section>

<section style="padding: 64px 24px; max-width: 768px; margin: 0 auto;" class="rte">
  {{ page.content }}
</section>

<style>
.rte p { margin-bottom: 20px; font-size: 16px; line-height: 1.7; color: var(--muted-fg); }
.rte h2 { font-family: var(--font-display); font-size: 32px; margin: 48px 0 16px; color: var(--fg); }
.rte h3 { font-family: var(--font-display); font-size: 24px; margin: 32px 0 12px; color: var(--fg); }
.rte a { text-decoration: underline; }
</style>

{% schema %}
{
  "name": "Page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Maison Noir" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" }
  ]
}
{% endschema %}
