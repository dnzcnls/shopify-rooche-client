<section class="page-head">
  <div class="page-eyebrow">Reset Password</div>
  <h1 class="page-title">New Password</h1>
</section>
<section style="max-width:420px; margin: 48px auto; padding: 0 24px;">
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}
      <ul class="errors-list">{%- for field in form.errors -%}<li>{{ form.errors.messages[field] }}</li>{%- endfor -%}</ul>
    {%- endif -%}
    <div class="field"><label>New Password</label><input type="password" name="customer[password]" required></div>
    <div class="field"><label>Confirm New Password</label><input type="password" name="customer[password_confirmation]" required></div>
    <button type="submit" class="btn btn-primary btn-block">Reset Password</button>
  {%- endform -%}
</section>
